# 數據庫配置
DATABASE_URL=postgresql://user:password@localhost:5432/whatsapp_bot

# Twilio配置
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Cloudinary配置（可選）
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# 應用配置
SECRET_KEY=your-super-secret-key-here
ENVIRONMENT=development  # development/production
DEBUG=true  # true/false

# API配置
API_V1_STR=/api/v1
PROJECT_NAME=WhatsApp訂單機器人

# CORS配置
BACKEND_CORS_ORIGINS=["*"]  # 生產環境應該限制為實際域名

# 安全配置
ACCESS_TOKEN_EXPIRE_MINUTES=11520  # 8天
ALGORITHM=HS256

# 限流配置
RATE_LIMIT_PER_MINUTE=60

# 管理員配置
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password  # 首次運行時需要修改