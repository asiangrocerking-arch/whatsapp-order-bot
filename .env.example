# 環境配置
ENVIRONMENT=development  # development, production
PORT=8000
HOST=0.0.0.0

# 數據庫配置
DATABASE_URL=postgresql://user:password@localhost/whatsapp_order_bot
# 或使用 SQLite 開發
# DATABASE_URL=sqlite:///./whatsapp_order_bot.db

# Twilio WhatsApp API 配置
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886  # Sandbox 號碼

# Cloudinary 圖片儲存配置
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name

# JWT 認證配置
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 管理員默認帳號（首次啟動時創建）
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeThisPassword123

# 應用配置
APP_NAME=WhatsApp Order Bot
APP_DESCRIPTION=一個經濟型的 WhatsApp 訂單處理系統
APP_VERSION=1.0.0

# CORS 配置（開發環境允許所有）
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# 訂單配置
ORDER_CONFIRMATION_REQUIRED=true
DEFAULT_DELIVERY_METHODS=["自取", "送貨"]
MAX_ORDER_QUANTITY=10